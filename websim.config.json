{
  "database": {
    "schema": {
      "characters_v1": {
        "sprite_url": {
          "type": "text",
          "description": "URL of the generated character sprite"
        },
        "original_image_url": {
          "type": "text",
          "description": "URL of the user's original portrait photo (optional)"
        },
        "prompt": {
          "type": "text",
